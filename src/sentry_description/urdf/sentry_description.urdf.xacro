<?xml version="1.0"?>
<robot name="sentry_robot" xmlns:xacro="http://ros.org/wiki/xacro">

    <!-- Define robot constants (that we arent using)-->
  <xacro:property name="base_width" value="0.540"/>
  <xacro:property name="base_length" value="0.530"/> <!--in direction of turret-->
  <xacro:property name="base_height" value="0.066"/>
  <xacro:property name="ground_offset" value="0.093"/>

  <xacro:property name="wheel_radius" value="0.075"/>
  <xacro:property name="wheel_width" value="0.04"/>
  <xacro:property name="wheel_mass" value="0.5"/>

  <xacro:property name="wheel_turret_dir_offset" value="0.2048"/>
  <xacro:property name="wheel_anti_turret_dir_offset" value="0.1986"/>


  <xacro:property name="gimbal_radius" value="0.0335"/>
  <xacro:property name="gimbal_height" value="0.076"/>

  <xacro:property name="lidar_length" value="0.054"/>
  <xacro:property name="lidar_width" value="0.04629"/>
  <xacro:property name="lidar_height" value="0.0348"/>

  <xacro:property name="support_width" value="0.3048"/>
  <xacro:property name="support_length" value="0.0699"/>
  <xacro:property name="support_base_height" value="0.075"/>

  <xacro:property name="support_standoff_width" value="0.058"/>
  <xacro:property name="support_standoff_length" value="0.0762"/>
  <xacro:property name="support_standoff_height" value="0.197"/>

  <xacro:property name="turret_shaft_radius" value="0.01"/>

  <xacro:property name="turret_length" value="0.18"/>
  <xacro:property name="turret_width" value="0.262"/>
  <xacro:property name="turret_height" value="0.15"/>
  <xacro:property name="turret_height_offset" value="0.03"/>


  <xacro:property name="mass" value="20"/>

  <!-- Define inertial property macros  -->
  <xacro:macro name="box_inertia" params="m w h d">
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="${m}"/>
    <inertia
      ixx="${(m/12) * (h*h + d*d)}"
      ixy="0"
      ixz="0"
      iyy="${(m/12) * (w*w + d*d)}"
      iyz="0"
      izz="${(m/12) * (w*w + h*h)}"/>
  </inertial>
</xacro:macro>


  <xacro:macro name="cylinder_inertia" params="m rad h">
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="${m}"/>
    <inertia
      ixx="${(m/12) * (3*rad*rad + h*h)}"
      ixy="0"
      ixz="0"
      iyy="${(m/12) * (3*rad*rad + h*h)}"
      iyz="0"
      izz="${(m/2) * (rad*rad)}"/>
  </inertial>
</xacro:macro>


  <!-- Base Link -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${base_height/2 + ground_offset}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_width} ${base_length} ${base_height}"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 0.8 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_height/2 + ground_offset}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_width} ${base_length} ${base_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${mass}" w="${base_width}" d="${base_length}" h="${base_height}"/>
  </link>
  
  <!-- Front Left Wheel -->
  <link name="front_left_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <xacro:cylinder_inertia m="${wheel_mass}" rad="${wheel_radius}" h="${wheel_width}"/>
  </link>
  
  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="${wheel_anti_turret_dir_offset} ${wheel_turret_dir_offset} ${wheel_radius}" rpy="0 1.5708 0"/>
    <dynamics damping="0.1" friction="0.1"/>
    <axis xyz="0 0 1"/>
  </joint>
  
  <!-- Front Right Wheel -->
  <link name="front_right_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <xacro:cylinder_inertia m="${wheel_mass}" rad="${wheel_radius}" h="${wheel_width}"/>
  </link>
  
  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="${-wheel_anti_turret_dir_offset} ${wheel_turret_dir_offset} ${wheel_radius}" rpy="0 1.5708 0"/>
    <dynamics damping="0.1" friction="0.1"/>
    <axis xyz="0 0 1"/>
  </joint>
  
  <!-- Back Left Wheel -->
  <link name="back_left_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <xacro:cylinder_inertia m="${wheel_mass}" rad="${wheel_radius}" h="${wheel_width}"/>
  </link>
  
  <joint name="back_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="back_left_wheel"/>
    <origin xyz="${wheel_anti_turret_dir_offset} ${-wheel_turret_dir_offset} ${wheel_radius}" rpy="0 1.5708 0"/>
    <dynamics damping="0.1" friction="0.1"/>
    <axis xyz="0 0 1"/>
  </joint>
  
  <!-- Back Right Wheel -->
  <link name="back_right_wheel">
    <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="${wheel_mass}" rad="${wheel_radius}" h="${wheel_width}"/>
  </link>
  
  <joint name="back_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="back_right_wheel"/>
    <origin xyz="${-wheel_anti_turret_dir_offset} ${-wheel_turret_dir_offset} ${wheel_radius}" rpy="0 1.5708 0"/>
    <dynamics damping="0.1" friction="0.1"/>
    <axis xyz="0 0 1"/>
  </joint>
  
   <link name="gimbal_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${gimbal_radius}" length="${gimbal_height}"/>
      </geometry>
      <material name="Cyan">
        <color rgba="0 1.0 1.0 1.0"/>
      </material>
    </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${gimbal_radius}" length="${gimbal_height}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="0.5" rad="${gimbal_radius}" h="${gimbal_height}"/>
  </link>
  <!-- Locked revolute for now: published in /joint_states, but held at 0 rad -->
  <joint name="gimbal_joint" type="revolute">
      <parent link="base_link"/>
      <child link="gimbal_link"/>
      <origin xyz="0 0 ${base_height + ground_offset + gimbal_height/2}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-0.0001" upper="0.0001" effort="100.0" velocity="0.01"/>
      <dynamics damping="500.0" friction="100.0"/>
  </joint>


   <!-- support_base -->
  <link name="bottom_support_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${support_width} ${support_length} ${support_base_height}"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${support_width} ${support_length} ${support_base_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${0.5}" w="${support_width * 2 + 2 * gimbal_radius}" d="${support_length}" h="${support_base_height}"/>
  </link>

   <joint name="bottom_support_joint" type="fixed">
      <parent link="gimbal_link"/>
      <child link="bottom_support_link"/>
      <origin xyz="0 0 ${support_base_height / 2}" rpy="0 0 0"/>
  </joint>

  <!-- LSL -->
  <link name="right_support_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${support_standoff_width} ${support_standoff_length} ${support_standoff_height}"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${support_standoff_width} ${support_standoff_length} ${support_standoff_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${0.5}" w="${support_standoff_width}" d="${support_standoff_length}" h="${support_standoff_height}"/>
  </link>

   <joint name="right_support_joint" type="fixed">
      <parent link="bottom_support_link"/>
      <child link="right_support_link"/>
      <origin xyz="${(support_width/2 - support_standoff_width/2)} 0 ${(support_standoff_height - support_base_height)/2}" rpy="0 0 0"/>
  </joint>

  <!-- RSL -->
  <link name="left_support_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${support_standoff_width} ${support_standoff_length} ${support_standoff_height}"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${support_standoff_width} ${support_standoff_length} ${support_standoff_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${0.5}" w="${support_standoff_width}" d="${support_standoff_length}" h="${support_standoff_height}"/>
  </link>

   <joint name="left_support_joint" type="fixed">
      <parent link="bottom_support_link"/>
      <child link="left_support_link"/>
      <origin xyz="${-(support_width/2 - support_standoff_width/2)} 0 ${(support_standoff_height - support_base_height)/2}" rpy="0 0 0"/>
  </joint>

  <!-- Turret shaft -->
  <link name="turret_shaft_link">
    <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${turret_shaft_radius}" length="${2*(support_width/2 - support_standoff_width/2)}"/>
      </geometry>
      <material name="yellow">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${turret_shaft_radius}" length="${2*(support_width + gimbal_radius)}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="${0.5}" rad="${turret_shaft_radius}" h="${2*(support_width + gimbal_radius)}"/>
  </link>
  
  <!-- Locked revolute for now: published in /joint_states, but held at 0 rad -->
  <joint name="turret_shaft_joint" type="revolute">
    <parent link="bottom_support_link"/>
    <child link="turret_shaft_link"/>
    <origin xyz="0 0 ${0.75 * support_standoff_height}" rpy="0 1.5708 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.0001" upper="0.0001" effort="100.0" velocity="0.01"/>
    <dynamics damping="500.0" friction="100.0"/>
  </joint>

  <!-- Turret box -->
  <link name="turret_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${turret_width} ${turret_length} ${turret_height}"/>
      </geometry>
      <material name="green">
        <color rgba="1 1 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${turret_width} ${turret_length} ${turret_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="3" w="${turret_width}" d="${turret_length}" h="${turret_height}"/>
  </link>

   <joint name="turret_joint" type="fixed">
      <parent link="turret_shaft_link"/>
      <child link="turret_link"/>
      <origin xyz="${-(turret_height_offset)} -0.014 0" rpy="1.5708 0 1.5708"/>
  </joint>

  <!-- gun barrel shaft -->
  <link name="gun_shaft_link">
    <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.15"/>
      </geometry>
      <material name="something">
        <color rgba="0 1 1 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.15"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="0.2" rad="0.02" h="0.15"/>
  </link>
  
  <joint name="gun_shaft_joint" type="fixed">
    <parent link="turret_link"/>
    <child link="gun_shaft_link"/>
    <origin xyz="${turret_length/2 + 0.025} 0 0" rpy="0 1.5708 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  

  <!-- LiDAR -->
  <link name="laser_frame_right">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.04"/>
      </geometry>
      <material name="purple">
        <color rgba="1 0 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" 
               iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="laser_joint_right" type="fixed">
    <parent link="right_support_link"/>
    <child link="laser_frame_right"/>
    <origin xyz="0 0 ${support_standoff_height / 2 + 0.02}" rpy="0 0 3.1415926535"/>
  </joint>

  <link name="laser_frame_left">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.04"/>
      </geometry>
      <material name="white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" 
               iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="laser_joint_left" type="fixed">
    <parent link="left_support_link"/>
    <child link="laser_frame_left"/>
    <origin xyz="0 0 ${support_standoff_height / 2 + 0.02}" rpy="0 0 0"/>
  </joint>

  <!-- IMU -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.01"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" 
               iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
  </link>
  
  <joint name="imu_joint" type="fixed">
    <parent link="turret_link"/>
    <child link="imu_link"/>
    <origin xyz="${-(turret_width - 0.02)/2} 0 0" rpy="0 0 0"/>
  </joint>
  
  <!-- depth camera-->
  <link name="depth_camera_link">
  <visual>
    <geometry>
      <box size="0.05 0.05 0.05"/>
    </geometry>
    <material name="camera_gray">
      <color rgba="0.5 0.5 0.5 1"/>
    </material>
  </visual>

  <collision>
    <geometry>
      <box size="0.05 0.05 0.05"/>
    </geometry>
  </collision>

  <inertial>
    <mass value="0.05"/>
    <inertia
      ixx="1e-5" ixy="0" ixz="0"
      iyy="1e-5" iyz="0"
      izz="1e-5"/>
  </inertial>
  </link>

  <joint name="depth_camera_joint" type="fixed">
  <parent link="turret_link"/>
  <child link="depth_camera_link"/>
  <origin xyz="0.05 0 ${-1 * (turret_height / 2  + 0.025)}" rpy="0 0 0"/>
  </joint>


    <!-- Gazebo-specific properties for base_link -->
    <gazebo reference="base_link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1.0</maxVel>
    </gazebo>

    <!-- Gazebo-specific properties for wheels -->
    <gazebo reference="front_left_wheel">
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
        <kp>1000000.0</kp>
        <kd>1.0</kd>
        <minDepth>0.001</minDepth>
        <material>Gazebo/Black</material>
    </gazebo>

    <gazebo reference="front_right_wheel">
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
        <kp>1000000.0</kp>
        <kd>1.0</kd>
        <minDepth>0.001</minDepth>
        <material>Gazebo/Black</material>
    </gazebo>

    <gazebo reference="back_left_wheel">
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
        <kp>1000000.0</kp>
        <kd>1.0</kd>
        <minDepth>0.001</minDepth>
        <material>Gazebo/Black</material>
    </gazebo>

    <gazebo reference="back_right_wheel">
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
        <kp>1000000.0</kp>
        <kd>1.0</kd>
        <minDepth>0.001</minDepth>
        <material>Gazebo/Black</material>
    </gazebo>

<!-- Gazebo Planar Move Plugin (for omnidirectional motion) -->
  <gazebo>
    <plugin name="planar_move" filename="libgazebo_ros_planar_move.so">
      <ros>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>
      <update_rate>50</update_rate>
      <publish_rate>50</publish_rate>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>
  </gazebo>
  
  <!-- Joint State Publisher Plugin (publishes wheel joint states) -->
  <gazebo>
    <plugin name="gazebo_ros_joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <update_rate>50</update_rate>
      <joint_name>front_left_wheel_joint</joint_name>
      <joint_name>front_right_wheel_joint</joint_name>
      <joint_name>back_left_wheel_joint</joint_name>
      <joint_name>back_right_wheel_joint</joint_name>
      <joint_name>gimbal_joint</joint_name>
      <joint_name>turret_shaft_joint</joint_name>
    </plugin>
  </gazebo>

  <!-- LiDAR Plugin -->
  <gazebo reference="laser_frame_left">
    <sensor name="laser_left" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>241</samples>
            <resolution>1</resolution>
            <min_angle>1.0471975512</min_angle>
            <max_angle>5.2359877560</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.1</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin name="laser_controller_left" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=/scan_left</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>laser_frame_left</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="laser_frame_right">
    <sensor name="laser_right" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>121</samples>
            <resolution>1</resolution>
            <min_angle>1.0471975512</min_angle>
            <max_angle>5.2359877560</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.1</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin name="laser_controller_right" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=/scan_right</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>laser_frame_right</frame_name>
      </plugin>
    </sensor>
  </gazebo>


  <!-- IMU Plugin -->
  <gazebo reference="imu_link">
    <gravity>true</gravity>
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
        <ros>
          <remapping>~/out:=imu</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Depth camera Plugin -->
  <gazebo reference="depth_camera_link">
  <sensor type="depth" name="depth_camera">
    <update_rate>30</update_rate>

    <camera>
      <horizontal_fov>1.047</horizontal_fov> <!-- 60 deg -->

      <image>
        <width>640</width>
        <height>480</height>
        <format>R8G8B8</format>
      </image>

      <clip>
        <near>0.1</near>
        <far>10.0</far>
      </clip>
    </camera>

    <plugin name="depth_camera_controller" filename="libgazebo_ros_depth_camera.so">
      <ros>
        <namespace>/sentry</namespace>
      </ros>

      <frame_name>depth_camera_link</frame_name>

      <image_topic_name>image_raw</image_topic_name>
      <depth_image_topic_name>depth/image_raw</depth_image_topic_name>
      <camera_info_topic_name>camera_info</camera_info_topic_name>

      <point_cloud>true</point_cloud>
      <point_cloud_topic_name>points</point_cloud_topic_name>
    </plugin>
  </sensor>
</gazebo>

</robot>
