<?xml version="1.0"?>
<robot name="sentry_robot" xmlns:xacro="http://ros.org/wiki/xacro">
  
    <!-- Define robot constants (that we arent using)-->
  <xacro:property name="base_width" value="0.495"/>
  <xacro:property name="base_length" value="0.495"/>
  <xacro:property name="base_height" value="0.18"/>
  <xacro:property name="ground_offset" value="0.05"/>


  <xacro:property name="wheel_radius" value="0.1"/>
  <xacro:property name="wheel_width" value="0.05"/>
  <xacro:property name="wheel_mass" value="0.5"/>

  <xacro:property name="gimbal_radius" value="0.05"/>
  <xacro:property name="gimbal_height" value="0.09"/>

  <xacro:property name="lidar_length" value="0.054"/>
  <xacro:property name="lidar_width" value="0.04629"/>
  <xacro:property name="lidar_height" value="0.0348"/>

  <xacro:property name="mass" value="20"/>

  <!-- Define inertial property macros  -->
  <xacro:macro name="box_inertia" params="m w h d">
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="${m}"/>
    <inertia
      ixx="${(m/12) * (h*h + d*d)}"
      ixy="0"
      ixz="0"
      iyy="${(m/12) * (w*w + d*d)}"
      iyz="0"
      izz="${(m/12) * (w*w + h*h)}"/>
  </inertial>
</xacro:macro>


  <xacro:macro name="cylinder_inertia" params="m rad h">
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="${m}"/>
    <inertia
      ixx="${(m/12) * (3*rad*rad + h*h)}"
      ixy="0"
      ixz="0"
      iyy="${(m/12) * (3*rad*rad + h*h)}"
      iyz="0"
      izz="${(m/2) * (rad*rad)}"/>
  </inertial>
</xacro:macro>


  <!-- Base Link -->
  <link name="base_link">
    <origin xyz="0 0 ${base_height/2 + ground_offset}" rpy="0 0 0"/>
    <visual>
      <origin xyz="0 0 ${base_height/2 + ground_offset}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_width} ${base_length} ${base_height}"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 0.8 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <origin xyz="0 0 ${base_height/2 + ground_offset}" rpy="0 0 0"/>
        <box size="${base_width} ${base_length} ${base_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${mass}" w="${base_width}" d="${base_length}" h="${base_height}"/>
  </link>
  
  <!-- Front Left Wheel -->
  <link name="front_left_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <xacro:cylinder_inertia m="${wheel_mass}" rad="${wheel_radius}" h="${wheel_width}"/>
  </link>
  
  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="${base_width/2 + wheel_width/2} ${base_length/2 + wheel_width/2} ${wheel_radius}" rpy="0 1.5708 0"/>
    <dynamics damping="0.1" friction="0.1"/>
    <axis xyz="0 1 0"/>
  </joint>
  
  <!-- Front Right Wheel -->
  <link name="front_right_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <xacro:cylinder_inertia m="${wheel_mass}" rad="${wheel_radius}" h="${wheel_width}"/>
  </link>
  
  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="${-1 * base_width/2 - wheel_width/2} ${base_length/2 + wheel_width/2} ${wheel_radius}" rpy="0 1.5708 0"/>
    <dynamics damping="0.1" friction="0.1"/>
    <axis xyz="0 1 0"/>
  </joint>
  
  <!-- Back Left Wheel -->
  <link name="back_left_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <xacro:cylinder_inertia m="${wheel_mass}" rad="${wheel_radius}" h="${wheel_width}"/>
  </link>
  
  <joint name="back_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="back_left_wheel"/>
    <origin xyz="${base_width/2 + wheel_width/2} ${-1*base_length/2 - wheel_width/2} ${wheel_radius}" rpy="0 1.5708 0"/>
    <dynamics damping="0.1" friction="0.1"/>
    <axis xyz="0 1 0"/>
  </joint>
  
  <!-- Back Right Wheel -->
  <link name="back_right_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <xacro:cylinder_inertia m="${wheel_mass}" rad="${wheel_radius}" h="${wheel_width}"/>
  </link>
  
  <joint name="back_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="back_right_wheel"/>
    <origin xyz="${-1 * base_width/2 - wheel_width/2} ${-1*base_length/2 - wheel_width/2} ${wheel_radius}" rpy="0 1.5708 0"/>
    <dynamics damping="0.1" friction="0.1"/>
    <axis xyz="0 1 0"/>
  </joint>
  
  <!-- LiDAR -->
  <link name="laser_frame">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.04"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" 
               iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>
  
  <!-- IMU -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.01"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" 
               iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
  </link>
  
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>
  

    <!-- Gazebo-specific properties for base_link -->
    <gazebo reference="base_link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1.0</maxVel>
    </gazebo>

    <!-- Gazebo-specific properties for wheels -->
    <gazebo reference="front_left_wheel">
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
        <kp>1000000.0</kp>
        <kd>1.0</kd>
        <minDepth>0.001</minDepth>
        <material>Gazebo/Black</material>
    </gazebo>

    <gazebo reference="front_right_wheel">
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
        <kp>1000000.0</kp>
        <kd>1.0</kd>
        <minDepth>0.001</minDepth>
        <material>Gazebo/Black</material>
    </gazebo>

    <gazebo reference="back_left_wheel">
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
        <kp>1000000.0</kp>
        <kd>1.0</kd>
        <minDepth>0.001</minDepth>
        <material>Gazebo/Black</material>
    </gazebo>

    <gazebo reference="back_right_wheel">
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
        <kp>1000000.0</kp>
        <kd>1.0</kd>
        <minDepth>0.001</minDepth>
        <material>Gazebo/Black</material>
    </gazebo>

<!-- Gazebo Planar Move Plugin (for omnidirectional motion) -->
  <gazebo>
    <plugin name="planar_move" filename="libgazebo_ros_planar_move.so">
      <update_rate>50</update_rate>
      <publish_rate>50</publish_rate>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <cmd_vel_topic>cmd_vel</cmd_vel_topic>
      <odometry_topic>odom</odometry_topic>
      <covariance_x>0.0001</covariance_x>
      <covariance_y>0.0001</covariance_y>
      <covariance_yaw>0.01</covariance_yaw>
    </plugin>
  </gazebo>
  
  <!-- Joint State Publisher Plugin (publishes wheel joint states) -->
  <gazebo>
    <plugin name="gazebo_ros_joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <update_rate>50</update_rate>
      <joint_name>front_left_wheel_joint</joint_name>
      <joint_name>front_right_wheel_joint</joint_name>
      <joint_name>back_left_wheel_joint</joint_name>
      <joint_name>back_right_wheel_joint</joint_name>
    </plugin>
  </gazebo>

  <!-- LiDAR Plugin -->
  <gazebo reference="laser_frame">
    <sensor name="laser" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.1</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin name="laser_controller" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>laser_frame</frame_name>
      </plugin>
    </sensor>
  </gazebo>
  
  <!-- IMU Plugin -->
  <gazebo reference="imu_link">
    <gravity>true</gravity>
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
        <ros>
          <remapping>~/out:=imu</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
    </sensor>
  </gazebo>
  
</robot>