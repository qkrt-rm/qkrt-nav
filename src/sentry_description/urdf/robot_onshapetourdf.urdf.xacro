      <geometry><mesh filename="${mesh_prefix}/plates_connecter.stl"/></geometry>
      <material name="aluminum"/>
    </visual>

    <!-- Shock absorbers (visual only, 8 units) -->
    <xacro:shock_absorber xyz="-0.219758 0.105883 0.141021"  rpy="-3.14159 -1.41814 -1.5708"/>
    <xacro:shock_absorber xyz="0.219758 0.000947 0.124876"   rpy="-0 -1.41814 -1.5708"/>
