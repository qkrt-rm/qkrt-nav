    </visual>
    <visual>
      <origin xyz="0.194 -0.035309 0.117457" rpy="2.68986 -0 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/plates_connecter.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="0.194 -0.035309 -0.117457" rpy="-0.451732 0 -0"/>
      <geometry><mesh filename="${mesh_prefix}/plates_connecter.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="-0.194 -0.035309 -0.117457" rpy="-0.451732 0 -0"/>
      <geometry><mesh filename="${mesh_prefix}/plates_connecter.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
