    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.45 0.38 0.45"/></geometry>
    </collision>
  </link>

  <!-- ==================== Wheel Links ==================== -->

  <!-- front_left_wheel_link -->
  <link name="front_left_wheel_link">
    <xacro:inertial_block mass="${wheel_mass}" ixx="${wheel_ixx}" iyy="${wheel_iyy}" izz="${wheel_izz}"/>

    <visual>
      <origin xyz="0.109996 -0.04853 0.064179" rpy="-2.68986 -0 3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/m3508_motor_fixplate4.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="0.036996 -0.024592 0.05697" rpy="3.14159 -0.292535 -1.5708"/>
      <geometry><mesh filename="${mesh_prefix}/3508_protector.stl"/></geometry>
      <material name="rubber"/>
    </visual>
    <visual>
      <origin xyz="0.167896 -0.04853 0.064179" rpy="-2.19706 0 -0"/>
      <geometry><mesh filename="${mesh_prefix}/wheel_bearing_flang.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="0.190808 -0.04853 0.064179" rpy="-2.68986 -0 3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/wheel_bearing_fixplate4.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="0.139296 -0.04853 0.064179" rpy="-3.03893 -0 3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/m3508_flang.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="-0.127004 -0.072468 0.071389" rpy="-3.14159 0.292535 1.5708"/>
      <geometry><mesh filename="${mesh_prefix}/3508_protector.stl"/></geometry>
      <material name="rubber"/>
    </visual>
    <visual>
      <origin xyz="0.020555 -0.0316 0.057086" rpy="1.5708 -1.0764 1.5708"/>
      <geometry><mesh filename="${mesh_prefix}/robomaster_m3508_p19_brushless_dc_gear_motor_non_cable.stl"/></geometry>
      <material name="steel"/>
    </visual>
    <visual>
      <origin xyz="-0.110563 -0.052023 0.0822" rpy="-1.5708 -0.289064 1.5708"/>
      <geometry><mesh filename="${mesh_prefix}/robomaster_m3508_p19_brushless_dc_gear_motor_non_cable.stl"/></geometry>
      <material name="steel"/>
    </visual>
    <xacro:wheel_rollers index="1" roller_rpy="1.5708 1.309 1.5708"/>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 1.5708"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
    </collision>
  </link>

  <!-- front_right_wheel_link -->
  <link name="front_right_wheel_link">
    <xacro:inertial_block mass="${wheel_mass}" ixx="${wheel_ixx}" iyy="${wheel_iyy}" izz="${wheel_izz}"/>

    <visual>
      <origin xyz="0.056123 -0.04853 -0.15984" rpy="-1.46813 -0 3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/wheel_bearing_flang.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="0.084723 -0.04853 -0.15984" rpy="-1.67346 0 -0"/>
      <geometry><mesh filename="${mesh_prefix}/m3508_flang.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="0.117023 -0.04853 -0.15984" rpy="-2.68986 -0 3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/m3508_motor_fixplate4.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="0.036211 -0.04853 -0.15984" rpy="-2.68986 -0 3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/wheel_bearing_fixplate4.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <xacro:wheel_rollers index="1" roller_rpy="-3.14159 -0 2.87979"/>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 1.5708"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
    </collision>
  </link>

  <!-- rear_left_wheel_link -->
  <link name="rear_left_wheel_link">
    <xacro:inertial_block mass="${wheel_mass}" ixx="${wheel_ixx}" iyy="${wheel_iyy}" izz="${wheel_izz}"/>

    <visual>
      <origin xyz="-0.056123 -0.04853 0.15984" rpy="1.67346 0 0"/>
      <geometry><mesh filename="${mesh_prefix}/wheel_bearing_flang.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="-0.084723 -0.04853 0.15984" rpy="1.46813 -0 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/m3508_flang.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="-0.117023 -0.04853 0.15984" rpy="0.451732 0 0"/>
      <geometry><mesh filename="${mesh_prefix}/m3508_motor_fixplate4.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="-0.036211 -0.04853 0.15984" rpy="0.451732 0 0"/>
      <geometry><mesh filename="${mesh_prefix}/wheel_bearing_fixplate4.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <xacro:wheel_rollers index="1" roller_rpy="0 -0 0.261799"/>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 1.5708"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
    </collision>
  </link>

  <!-- rear_right_wheel_link -->
  <link name="rear_right_wheel_link">
    <xacro:inertial_block mass="${wheel_mass}" ixx="${wheel_ixx}" iyy="${wheel_iyy}" izz="${wheel_izz}"/>

    <visual>
      <origin xyz="0.127004 -0.072468 -0.071216" rpy="0 -0.292535 1.5708"/>
      <geometry><mesh filename="${mesh_prefix}/3508_protector.stl"/></geometry>
      <material name="rubber"/>
    </visual>
    <visual>
      <origin xyz="-0.109996 -0.04853 -0.064006" rpy="0.451732 0 0"/>
      <geometry><mesh filename="${mesh_prefix}/m3508_motor_fixplate4.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="-0.036996 -0.024592 -0.056797" rpy="-0 0.292535 -1.5708"/>
      <geometry><mesh filename="${mesh_prefix}/3508_protector.stl"/></geometry>
      <material name="rubber"/>
    </visual>
    <visual>
      <origin xyz="-0.167896 -0.04853 -0.064006" rpy="0.944531 -0 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/wheel_bearing_flang.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="-0.190808 -0.04853 -0.064006" rpy="0.451732 0 0"/>
      <geometry><mesh filename="${mesh_prefix}/wheel_bearing_fixplate4.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="-0.139296 -0.04853 -0.064006" rpy="0.102666 0 0"/>
      <geometry><mesh filename="${mesh_prefix}/m3508_flang.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="0.110563 -0.052023 -0.082027" rpy="1.5708 0.289064 1.5708"/>
      <geometry><mesh filename="${mesh_prefix}/robomaster_m3508_p19_brushless_dc_gear_motor_non_cable.stl"/></geometry>
      <material name="steel"/>
    </visual>
    <xacro:wheel_rollers index="1" roller_rpy="-1.5708 -1.309 1.5708"/>
    <visual>
      <origin xyz="-0.020555 -0.0316 -0.056913" rpy="-1.5708 1.0764 1.5708"/>
      <geometry><mesh filename="${mesh_prefix}/robomaster_m3508_p19_brushless_dc_gear_motor_non_cable.stl"/></geometry>
      <material name="steel"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 1.5708"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
    </collision>
  </link>

  <!-- ==================== turret_yaw_link ==================== -->
  <!-- Gimbal vertical structure + pitch motor -->
  <link name="turret_yaw_link">
    <xacro:inertial_block mass="1.5" ixx="0.00461" iyy="0.0218" izz="0.02281"/>

    <visual>
      <origin xyz="0.1947 0 0" rpy="1.5708 1.0472 1.5708"/>
      <geometry><mesh filename="${mesh_prefix}/part_1.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="-0.1574 0 0" rpy="-1.5708 -0 0"/>
      <geometry><mesh filename="${mesh_prefix}/gimbal_shaft_simple.stl"/></geometry>
      <material name="carbon_fiber"/>
    </visual>
    <visual>
      <origin xyz="0 -0.15875 0.040481" rpy="-1.5708 0 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/gimbal_jetson_side_carbon.stl"/></geometry>
      <material name="carbon_fiber"/>
    </visual>
    <visual>
      <origin xyz="-0.127 0 0" rpy="0 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/gimbal_tube_top_shaft.stl"/></geometry>
      <material name="carbon_fiber"/>
    </visual>
    <visual>
      <origin xyz="-0.081329 -0.082709 0" rpy="0.756835 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/gimbal_tube_reinforce.stl"/></geometry>
      <material name="carbon_fiber"/>
    </visual>
    <visual>
      <origin xyz="0.081329 -0.082709 0" rpy="2.38476 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/gimbal_tube_reinforce.stl"/></geometry>
      <material name="carbon_fiber"/>
    </visual>
    <visual>
      <origin xyz="0 -0.15875 -0.040481" rpy="1.5708 -0 0"/>
      <geometry><mesh filename="${mesh_prefix}/gimbal_side_carbon.stl"/></geometry>
      <material name="carbon_fiber"/>
    </visual>
    <visual>
      <origin xyz="0.127 0 0" rpy="0 1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/gimbal_tube_top_motor.stl"/></geometry>
      <material name="carbon_fiber"/>
    </visual>
    <visual>
      <origin xyz="0.269448 0 0" rpy="1.5708 0.967525 1.5708"/>
      <geometry><mesh filename="${mesh_prefix}/top_robomaster_gm6020.stl"/></geometry>
      <material name="steel"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.40 0.16 0.12"/></geometry>
    </collision>
  </link>

  <!-- ==================== turret_pitch_link ==================== -->
  <!-- Barrels, flywheels, hoppers, sensors -->
  <link name="turret_pitch_link">
    <xacro:inertial_block mass="2.5" ixx="0.02175" iyy="0.02708" izz="0.01133"/>

    <!-- Barrels -->
    <visual>
      <origin xyz="0.0385 -0.0053 -0.0555" rpy="0 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/hiti_tech_barrel.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
      <origin xyz="-0.0385 -0.0053 -0.0555" rpy="-3.14159 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/hiti_tech_barrel.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
      <origin xyz="-0.0065 -0.0053 -0.0555" rpy="0 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/hiti_extended_barrel.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
      <origin xyz="0.0385 -0.0053 -0.0555" rpy="0 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/hiti_extended_barrel.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
      <origin xyz="0.0225 -0.0225 0.0045" rpy="-1.5708 -0 0"/>
      <geometry><mesh filename="${mesh_prefix}/barrel_extender.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
      <origin xyz="-0.0225 -0.0225 0.0045" rpy="-1.5708 -0 0"/>
      <geometry><mesh filename="${mesh_prefix}/barrel_extender.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>

    <!-- Flywheels -->
    <visual>
      <origin xyz="0.0045 -0.0053 -0.04292" rpy="-1.5708 1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/flywheel_support.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
      <origin xyz="-0.0045 -0.0053 -0.04292" rpy="1.5708 1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/flywheel_support.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>

    <!-- Hoppers and ammo -->
    <visual>
      <origin xyz="0.05 -0.0225 0.0695" rpy="1.5708 0 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/lefthopper.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
      <origin xyz="-0.05 -0.0225 0.0695" rpy="1.5708 0 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/right_hopper.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
      <origin xyz="-0.05 -0.0098 0.0695" rpy="-1.5708 -0 0"/>
      <geometry><mesh filename="${mesh_prefix}/indexer.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
      <origin xyz="0.05 -0.0098 0.0695" rpy="1.5708 -0.785398 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/indexer.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
      <origin xyz="0.001204 -0.059567 -0.255729" rpy="0 -0 0"/>
      <geometry><mesh filename="${mesh_prefix}/ammo_charger.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
      <origin xyz="-0.043796 -0.059567 -0.255729" rpy="0 -0 0"/>
      <geometry><mesh filename="${mesh_prefix}/ammo_charger.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>

    <!-- Sensors -->
    <visual>
      <origin xyz="0 0.0305 -0.1325" rpy="0 -0 0"/>
      <geometry><mesh filename="${mesh_prefix}/camera.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
      <origin xyz="0.0225 0.0655 -0.1055" rpy="1.5708 -0 0"/>
      <geometry><mesh filename="${mesh_prefix}/real_sense_mount.stl"/></geometry>
      <material name="orange_plastic"/>
    </visual>
    <visual>
      <origin xyz="-0.0225 0.0655 -0.1055" rpy="1.5708 -0 0"/>
      <geometry><mesh filename="${mesh_prefix}/real_sense_mount.stl"/></geometry>
      <material name="orange_plastic"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.20 0.12 0.30"/></geometry>
    </collision>
  </link>

  <!-- ==================== jetson_link ==================== -->
  <!-- Virtual box approximation for Nvidia Jetson -->
  <link name="jetson_link">
    <xacro:inertial_block mass="0.5" ixx="0.000304" iyy="0.000684" izz="0.000454"/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.10 0.03 0.08"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.10 0.03 0.08"/></geometry>
    </collision>
  </link>

  <!-- ==================== Joints ==================== -->

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="chassis_joint" type="revolute">
    <parent link="base_link"/>
    <child link="chassis_link"/>
    <origin xyz="0 -0.151048 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-${pi}" upper="${pi}" effort="${chassis_yaw_effort}" velocity="${chassis_yaw_velocity}"/>
  </joint>

  <joint name="turret_yaw_joint" type="revolute">
    <parent link="base_link"/>
    <child link="turret_yaw_link"/>
    <origin xyz="0 0.117702 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-${pi}" upper="${pi}" effort="${turret_yaw_effort}" velocity="${turret_yaw_velocity}"/>
  </joint>

  <joint name="turret_pitch_joint" type="revolute">
    <parent link="turret_yaw_link"/>
    <child link="turret_pitch_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-${turret_pitch_limit}" upper="${turret_pitch_limit}" effort="${turret_pitch_effort}" velocity="${turret_pitch_velocity}"/>
  </joint>

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="chassis_link"/>
    <child link="front_left_wheel_link"/>
    <origin xyz="0.045004 -0.001392 -0.269023" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="${wheel_effort}" velocity="${wheel_velocity}"/>
  </joint>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="chassis_link"/>
    <child link="front_right_wheel_link"/>
    <origin xyz="-0.269023 -0.001392 -0.045004" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="${wheel_effort}" velocity="${wheel_velocity}"/>
  </joint>

  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="chassis_link"/>
    <child link="rear_left_wheel_link"/>
    <origin xyz="0.269023 -0.001392 0.045004" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="${wheel_effort}" velocity="${wheel_velocity}"/>
  </joint>

  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="chassis_link"/>
    <child link="rear_right_wheel_link"/>
    <origin xyz="-0.045004 -0.001392 0.268850" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="${wheel_effort}" velocity="${wheel_velocity}"/>
  </joint>

  <joint name="jetson_joint" type="fixed">
    <parent link="turret_yaw_link"/>
    <child link="jetson_link"/>
    <origin xyz="0 -0.159 0.041" rpy="0 0 0"/>
  </joint>

</robot>
