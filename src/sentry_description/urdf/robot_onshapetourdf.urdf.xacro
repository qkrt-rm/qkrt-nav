<?xml version="1.0" ?>
<!-- Clean xacro for RoboMaster Sentry Robot -->
<!-- Generated from monolithic OnShape export -->
<!-- Base link = GM6020 yaw motor center (fixed to world) -->
<!-- Coordinate system: Y-up, X-lateral, Z-forward/back -->
<robot name="sentry" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ==================== Properties ==================== -->
  <xacro:property name="mesh_prefix" value="package://assets"/>

  <!-- Wheel properties -->
  <xacro:property name="wheel_mass" value="1.2"/>
  <xacro:property name="wheel_radius" value="0.076"/>
  <xacro:property name="wheel_width" value="0.05"/>
  <xacro:property name="wheel_ixx" value="0.00347"/>
  <xacro:property name="wheel_iyy" value="0.00198"/>
  <xacro:property name="wheel_izz" value="0.00198"/>
  <xacro:property name="wheel_effort" value="10"/>
  <xacro:property name="wheel_velocity" value="50"/>

  <!-- Chassis properties -->
  <xacro:property name="chassis_mass" value="9.0"/>

  <!-- Turret properties -->
  <xacro:property name="turret_yaw_effort" value="5"/>
  <xacro:property name="turret_yaw_velocity" value="10"/>
  <xacro:property name="turret_pitch_effort" value="5"/>
  <xacro:property name="turret_pitch_velocity" value="5"/>
  <xacro:property name="turret_pitch_limit" value="0.5236"/>

  <!-- Chassis yaw properties -->
  <xacro:property name="chassis_yaw_effort" value="20"/>
  <xacro:property name="chassis_yaw_velocity" value="10"/>

  <!-- ==================== Materials ==================== -->
  <material name="carbon_fiber">
    <color rgba="0.15 0.15 0.15 1"/>
  </material>
  <material name="hard_plastic">
    <color rgba="0.30 0.30 0.30 1"/>
  </material>
  <material name="aluminum">
    <color rgba="0.75 0.75 0.75 1"/>
  </material>
  <material name="steel">
    <color rgba="0.40 0.40 0.45 1"/>
  </material>
  <material name="rubber">
    <color rgba="0.10 0.10 0.10 1"/>
  </material>
  <material name="orange_plastic">
    <color rgba="0.90 0.50 0.10 1"/>
  </material>
  <material name="light_blue">
    <color rgba="0.62 0.81 0.93 1"/>
  </material>

  <!-- ==================== Macros ==================== -->


  <xacro:macro name="roller" params="file roller_rpy">
    <visual>
      <origin xyz="0 0 0" rpy="${roller_rpy}"/>
      <geometry>
        <mesh filename="${mesh_prefix}/${file}.stl"/>
      </geometry>
      <material name="rubber"/>
    </visual>
  </xacro:macro>

  <xacro:macro name="wheel_rollers" params="index roller_rpy">

  <xacro:if value="${index &lt;= 16}">   

      <xacro:roller 
          file="${'%03d' % index}" 
          roller_rpy="${roller_rpy}"/>

      <xacro:wheel_rollers 
          index="${index + 1}" 
          roller_rpy="${roller_rpy}"/>

    </xacro:if>

  </xacro:macro>

  <!-- Macro: single shock absorber (3 sub-meshes at same origin) -->
  <xacro:macro name="shock_absorber" params="xyz rpy">
    <visual>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <geometry>
        <mesh filename="${mesh_prefix}/孔距85mm单筒式避震_step_1______0_step_1_solid1.stl"/>
      </geometry>
      <material name="steel"/>
    </visual>
    <visual>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <geometry>
        <mesh filename="${mesh_prefix}/孔距85mm单筒式避震_step_1_53_______step_1_solid1.stl"/>
      </geometry>
      <material name="steel"/>
    </visual>
    <visual>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <geometry>
        <mesh filename="${mesh_prefix}/孔距85mm单筒式避震_step_1______step_1_solid1.stl"/>
      </geometry>
      <material name="steel"/>
    </visual>
  </xacro:macro>

  <!-- Macro: standard inertial block -->
  <xacro:macro name="inertial_block" params="mass ixx iyy izz">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <inertia ixx="${ixx}" ixy="0" ixz="0" iyy="${iyy}" iyz="0" izz="${izz}"/>
    </inertial>
  </xacro:macro>

  <!-- ==================== World ==================== -->
  <link name="world"/>

  <!-- ==================== base_link ==================== -->
  <!-- GM6020 yaw motor + sentry gimbal mount structure -->
  <link name="base_link">
    <xacro:inertial_block mass="1.5" ixx="0.00274" iyy="0.00188" izz="0.00274"/>

    <visual>
      <origin xyz="0.04 -0.089548 0" rpy="0 1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/sentry_gimbal_bearing_deck_supportor.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="0 -0.022367 0" rpy="-3.14159 -1.0472 0"/>
      <geometry><mesh filename="${mesh_prefix}/360_rotate_ring_12_signals_2_a.stl"/></geometry>
      <material name="rubber"/>
    </visual>
    <visual>
      <origin xyz="0 -0.059048 0" rpy="-0 0.458625 -0"/>
      <geometry><mesh filename="${mesh_prefix}/sentry_gimbal_mock_bearing.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="0 -0.056548 0" rpy="3.14159 0.807199 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/sentry_gimbal_rotate_shaft_ring_housing.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="0 -0.117048 0" rpy="0 0 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/sentry_gimbal_mount_plate.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="0 -0.075048 0" rpy="3.14159 1.00828 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/sentry_gimbal_6020_shaft_adapter.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="0 -0.062048 0" rpy="-3.14159 0 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/sentry_gimbal_bearing_plate.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="-0.05 -0.089548 0" rpy="0 1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/sentry_gimbal_bearing_deck_supportor.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0.967525 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/top_robomaster_gm6020.stl"/></geometry>
      <material name="steel"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.06" length="0.15"/></geometry>
    </collision>
  </link>

  <!-- ==================== chassis_link ==================== -->
  <!-- Armor plates, structural frame, shock absorbers -->
  <link name="chassis_link">
    <xacro:inertial_block mass="${chassis_mass}" ixx="0.259" iyy="0.304" izz="0.259"/>

    <!-- Composite structural parts -->
    <visual>
      <origin xyz="0.006878 0.375486 0.050016" rpy="-3.14159 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/composite_part_1.stl"/></geometry>
      <material name="carbon_fiber"/>
    </visual>
    <visual>
      <origin xyz="-0.036 0.383605 -0.017955" rpy="-1.5708 -1.36061 1.5708"/>
      <geometry><mesh filename="${mesh_prefix}/composite_part_1.stl"/></geometry>
      <material name="carbon_fiber"/>
    </visual>
    <visual>
      <origin xyz="-0.041 0.33465 -0.0638" rpy="-3.14159 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/composite_part_1.stl"/></geometry>
      <material name="carbon_fiber"/>
    </visual>
    <visual>
      <origin xyz="0.041 0.33465 -0.0638" rpy="-3.14159 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/composite_part_1.stl"/></geometry>
      <material name="carbon_fiber"/>
    </visual>
    <visual>
      <origin xyz="0.0626 0.34925 -0.0313" rpy="-1.5708 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/composite_part_1.stl"/></geometry>
      <material name="carbon_fiber"/>
    </visual>
    <visual>
      <origin xyz="0.036 0.383605 -0.017955" rpy="-1.5708 -1.36061 1.5708"/>
      <geometry><mesh filename="${mesh_prefix}/composite_part_1.stl"/></geometry>
      <material name="carbon_fiber"/>
    </visual>
    <visual>
      <origin xyz="0.086 0.29525 0.1175" rpy="-1.5708 1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/composite_part_2.stl"/></geometry>
      <material name="carbon_fiber"/>
    </visual>
    <visual>
      <origin xyz="0.024192 0.094376 -0.017014" rpy="-1.5708 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/composite_part_1__2.stl"/></geometry>
      <material name="carbon_fiber"/>
    </visual>
    <visual>
      <origin xyz="0.024192 0.152376 -0.017014" rpy="-1.5708 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/composite_part_1__2.stl"/></geometry>
      <material name="carbon_fiber"/>
    </visual>
    <visual>
      <origin xyz="-0.024192 0.374524 -0.017014" rpy="1.5708 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/composite_part_1__2.stl"/></geometry>
      <material name="carbon_fiber"/>
    </visual>
    <visual>
      <origin xyz="-0.024192 0.432524 -0.017014" rpy="1.5708 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/composite_part_1__2.stl"/></geometry>
      <material name="carbon_fiber"/>
    </visual>
    <visual>
      <origin xyz="-0.032877 0.237055 0.058293" rpy="1.5708 -0.261799 0"/>
      <geometry><mesh filename="${mesh_prefix}/composite_part_1__3.stl"/></geometry>
      <material name="carbon_fiber"/>
    </visual>
    <visual>
      <origin xyz="0.051144 0.237055 0.089933" rpy="-1.5708 -0.785398 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/composite_part_1__3.stl"/></geometry>
      <material name="carbon_fiber"/>
    </visual>
    <visual>
      <origin xyz="0 0.34825 -0.14055" rpy="3.14159 0 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/composite_part_1__4.stl"/></geometry>
      <material name="carbon_fiber"/>
    </visual>
    <visual>
      <origin xyz="-0.0246 0.34985 -0.03118" rpy="1.5708 0 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/composite_part_1__5.stl"/></geometry>
      <material name="carbon_fiber"/>
    </visual>

    <!-- Brackets -->
    <visual>
      <origin xyz="0.058 0.29525 -0.103" rpy="1.5708 -0 1.5708"/>
      <geometry><mesh filename="${mesh_prefix}/middle_to_top_bracket.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="0.058 0.29525 0.012" rpy="1.5708 -0 1.5708"/>
      <geometry><mesh filename="${mesh_prefix}/middle_to_top_bracket.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="-0.068 0.32525 -0.103" rpy="-1.5708 0 -1.5708"/>
      <geometry><mesh filename="${mesh_prefix}/middle_to_top_bracket.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="-0.068 0.29525 0.012" rpy="1.5708 -0 1.5708"/>
      <geometry><mesh filename="${mesh_prefix}/middle_to_top_bracket.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="0.068 0.26875 -0.103" rpy="-1.5708 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/bottom_to_middle_bracket.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="-0.058 0.26875 -0.103" rpy="-1.5708 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/bottom_to_middle_bracket.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="0.068 0.32925 -0.0055" rpy="0 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/top_plate_tall_bracket.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
      <origin xyz="-0.058 0.32925 -0.0055" rpy="0 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/top_plate_tall_bracket.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
      <origin xyz="-0.058 0.32925 -0.1205" rpy="0 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/top_plate_short_bracket.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
      <origin xyz="0.068 0.32925 -0.1205" rpy="0 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/top_plate_short_bracket.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
      <origin xyz="-0.058 0.26875 -0.06" rpy="-1.5708 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/bottom_plate_special_bracket.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
