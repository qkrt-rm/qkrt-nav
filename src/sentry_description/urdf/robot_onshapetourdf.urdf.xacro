      <geometry><mesh filename="${mesh_prefix}/aluminium_beam_60x25_170.stl"/></geometry>
      <material name="aluminum"/>
    </visual>

    <!-- Infantry armor plates -->
    <visual>
      <origin xyz="0 -0.033 0.03" rpy="-3.14159 -0 3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/infantry_lower_platever2.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
      <origin xyz="0 0.03 0.1" rpy="-3.14159 -0 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/infantry_upper_plate_ver2.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
      <origin xyz="0 -0.033 -0.03" rpy="0 -0 0"/>
      <geometry><mesh filename="${mesh_prefix}/infantry_lower_front_platever2.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
