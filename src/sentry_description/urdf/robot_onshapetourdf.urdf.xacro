    </visual>
    <visual>
      <origin xyz="0 0.24225 -0.0055" rpy="1.5708 0 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/bottom_plate.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>

    <!-- Panels -->
    <visual>
      <origin xyz="0 0.30475 -0.1205" rpy="1.5708 0 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/front_panel.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
      <origin xyz="0.072 0.28575 -0.0455" rpy="1.5708 0 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/side_panel.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
      <origin xyz="-0.068 0.28575 -0.0455" rpy="1.5708 0 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/side_panel.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
      <origin xyz="0 0.38415 -0.041283" rpy="0.210183 0 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/top_panel.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>

    <!-- Gimbal tube bottom (vertical tube to yaw motor) -->
    <visual>
      <origin xyz="0 0.1354 0" rpy="1.5708 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/gimbal_tube_bottom.stl"/></geometry>
      <material name="carbon_fiber"/>
    </visual>

    <!-- Aluminium beams -->
    <visual>
      <origin xyz="0.0625 0 0" rpy="-3.14159 0 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/aluminium_beam_60x25_360.stl"/></geometry>
      <material name="aluminum"/>
    </visual>
    <visual>
      <origin xyz="-0.0625 0 0" rpy="0 -0 0"/>
      <geometry><mesh filename="${mesh_prefix}/aluminium_beam_60x25_360.stl"/></geometry>
