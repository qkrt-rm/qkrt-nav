    </visual>
    <visual>
      <origin xyz="-0.058 0.26875 0" rpy="-1.5708 -1.5708 0"/>
      <geometry><mesh filename="${mesh_prefix}/hex_shaft_connector.stl"/></geometry>
      <material name="steel"/>
    </visual>

    <!-- Armor plates -->
    <visual>
      <origin xyz="0 0.32525 -0.0455" rpy="1.5708 0 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/top_plate.stl"/></geometry>
      <material name="hard_plastic"/>
    </visual>
    <visual>
      <origin xyz="0 0.29125 -0.0225" rpy="1.5708 0 -3.14159"/>
      <geometry><mesh filename="${mesh_prefix}/middle_plate.stl"/></geometry>
