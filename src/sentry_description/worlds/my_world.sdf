<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="competition_world">
    
    <include>
      <uri>model://sun</uri>
    </include>
    
    <include>
      <uri>model://ground_plane</uri>
    </include>
    
    <!-- Competition arena walls (18m x 12m from your map) -->
    <model name="arena">  
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>
      
      <!--Note, the bounding walls are 0.1m thickness, and the position offset is half of that at 0.05m-->
      <!-- this is so our dimensions are exact, and are walls aren't poking into the map by a small amount-->

      <!-- North wall, +0.05 offset for wall thickness -->
      <link name="north_wall">
        <pose>0 4.05 0.25 0 0 0</pose>
        <collision name="collision">
          <geometry>
            <box>
              <size>12 0.1 0.5</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>12 0.1 0.5</size>
            </box>
          </geometry>
          <material>
            <ambient>0.25 0.25 0.25 1</ambient>
            <diffuse>0.25 0.25 0.25 1</diffuse>
          </material>
        </visual>
      </link>
      
      <!-- South wall,  minus 0.05 offset-->
      <link name="south_wall">
        <pose>0 -4.05 0.25 0 0 0</pose>
        <collision name="collision">
          <geometry>
            <box>
              <size>12 0.1 0.5</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>12 0.1 0.5</size>
            </box>
          </geometry>
          <material>
            <ambient>0.25 0.25 0.25 1</ambient>
            <diffuse>0.25 0.25 0.25 1</diffuse>
          </material>
        </visual>
      </link>
      
      <!-- East wall, plus 0.05 offset -->
      <link name="east_wall">
        <pose>6.05 0 0.25 0 0 0</pose>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.1 8 0.5</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.1 8 0.5</size>
            </box>
          </geometry>
          <material>
            <ambient>0.25 0.25 0.25 1</ambient>
            <diffuse>0.25 0.25 0.25 1</diffuse>
          </material>
        </visual>
      </link>
      
      <!-- West wall, minus 0.05 offset  -->
      <link name="west_wall">
        <pose>-6.05 0 0.25 0 0 0</pose>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.1 8 0.5</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.1 8 0.5</size>
            </box>
          </geometry>
          <material>
            <ambient>0.25 0.25 0.25 1</ambient>
            <diffuse>0.25 0.25 0.25 1</diffuse>
          </material>
        </visual>
      </link>

      <!-- West inner wall -->
      <link name="west_inner_wall_bottom"> <!-- -3.750 + 0.1 to account for width in x dir-->
        <pose>-3.650 -0.317 0.24 0 0 0</pose>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.2 3.0 0.42</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.2 3.0 0.42</size> 
            </box>
          </geometry>
          <material>
            <ambient>0.5 0.5 0.5 1</ambient>
            <diffuse>0.5 0.5 0.5 1</diffuse>
          </material>
        </visual>
      </link>


      <link name="west_inner_wall_top"> <!-- +0.1 to account for width in x dir-->
        <pose>-3.650 -0.317 0.9315 0 0 0</pose>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.05 2.7 0.987</size>
            </box>
