      <link name="centre_box_obstacle"> <!--should be -2.700, but for some reason, there is no gap between this box small tile (see official map)-->
        <pose>0 -2.800 0.24 0 0 0</pose>
        <collision name="collision">
          <geometry>
            <box>
              <size> 2 1 0.42</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>2 1 0.42</size> 
            </box>
          </geometry>
          <material>
            <ambient>0.7 0.7 0.7 1</ambient>
            <diffuse>0.7 0.7 0.7 1</diffuse>
          </material>
        </visual>
      </link>


      <!--For the slow zones, I am creating a larger one (the big block), a medium one (3 tiles adjacent)-->
      <!-- and then one additional tile (look at the schematic on the official ARC robotics website), on each side-->

      <link name="slow_zone_large_left">
        <pose>-3.580 -2.800 0.01 0 0 0</pose>

        <collision name="collision">
          <geometry>
            <box>
              <size>4 2 0.02</size>
            </box>
          </geometry>

          <surface>
            <friction>
              <ode>
                <!-- Lower values → less traction -->
                <mu>0.1</mu>
                <mu2>0.1</mu2>
              </ode>
            </friction>
          </surface>
        </collision>

        <visual name="visual">
          <geometry>
            <box>
              <size>4 2 0.02</size>
            </box>
          </geometry>
          <material>
            <ambient>1 1 0 1</ambient>   <!-- yellow -->
            <diffuse>1 1 0 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="slow_zone_medium_left">
        <pose>-1.38 -2.4 0.01 0 0 0</pose>

        <collision name="collision">
          <geometry>
            <box>
              <size>0.4 1.2 0.02</size>
            </box>
          </geometry>

          <surface>
