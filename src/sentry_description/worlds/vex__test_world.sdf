<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="vex_world"> 
  <!--gazebo /home/tony/qkrt-nav/src/sentry_description/worlds/vex__test_world.sdf-->

    <include>
      <uri>model://sun</uri>
    </include>

    <include>
      <uri>model://ground_plane</uri>
    </include>

    <!-- Competition arena walls (simple 4-wall boundary) -->
    <model name="arena_boundary">
      <static>true</static>

      <!-- LEFT WALL: thickness(X)=0.025, length(Y)=1.835, height(Z)=0.3 -->
      <link name="wall_left">
        <pose>-1.8225 0 0.15 0 0 0</pose>
        <collision name="col">
          <geometry><box><size>0.025 3.67 0.3</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>0.025 3.67 0.3</size></box></geometry>

          <material>
            <ambient>0.8 0.2 0.1 1</ambient> <!--enlight-->
            <diffuse>0.8 0.2 0.1 1</diffuse> <!--maincolor-->
            <!-- red green blue A -->
          </material>

        </visual>
      </link>

      <!-- RIGHT WALL -->
      <link name="wall_right">
        <pose>1.8225 0 0.15 0 0 0</pose>
        <collision name="col">
          <geometry><box><size>0.025 3.67 0.3</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>0.025 3.67 0.3</size></box></geometry>

          <material>
            <ambient>0.8 0.2 0.1 1</ambient> <!--enlight-->
            <diffuse>0.8 0.2 0.1 1</diffuse> <!--maincolor-->
            <!-- red green blue A -->
          </material>

        </visual>
      </link>

      <!-- TOP WALL: length(X)=3.595 to connect left/right walls -->
      <link name="wall_top">
        <pose>0 1.8225 0.15 0 0 0</pose>
        <collision name="col">
          <geometry><box><size>3.67 0.025 0.3</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>3.67 0.025 0.3</size></box></geometry>

          <material>
            <ambient>0.8 0.2 0.1 1</ambient> <!--enlight-->
            <diffuse>0.8 0.2 0.1 1</diffuse> <!--maincolor-->
            <!-- red green blue A -->
          </material>

        </visual>
      </link>

      <!-- BOTTOM WALL -->
      <link name="wall_bottom">
        <pose>0 -1.8225 0.15 0 0 0</pose>
        <collision name="col">
          <geometry><box><size>3.67 0.025 0.3</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>3.67 0.025 0.3</size></box></geometry>

          <material>
            <ambient>0.8 0.2 0.1 1</ambient> <!--enlight-->
            <diffuse>0.8 0.2 0.1 1</diffuse> <!--maincolor-->
            <!-- red green blue A -->
          </material>

        </visual>
      </link>


      <!-- Center pillar: square cross-section, rotated 45 degrees (yaw = pi/4) -->
      <link name="pillar_link">
        <!-- pose: x y z roll pitch yaw -->
        <!-- yaw=0.785398 rad = 45 degrees -->
        <pose>0 0 0.3 0 0 0.785398</pose>

        <collision name="col">
          <geometry>
            <box>
              <!-- size_x size_y size_z -->
              <size>0.41 0.41 0.60</size>
            </box>
          </geometry>
        </collision>

        <visual name="vis">
          <geometry>
            <box>
              <size>0.41 0.41 0.60</size>
            </box>
          </geometry>
        </visual>
      </link>



